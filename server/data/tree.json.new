    },
    {
      "id": "person-nancy-hanson",
      "firstName": "Nancy Lee",
      "lastName": "Hanson",
      "birthYear": "1930",
      "deathYear": "2015",
      "birthDate": "1930-10-08",
      "birthPlace": "Racine, Wisconsin",
      "deathDate": "2015-06-17",
      "deathPlace": "Eden Prairie, Minnesota",
      "notes": "CONFIRMED: obituary from Racine Journal Times (Jun 2015) confirms she was born October 8, 1930 in Racine, Wisconsin to Harry N. Sorenson and Emma (Timler) Sorenson. Died June 17, 2015 at Brookdale of Eden Prairie, MN. Graduated Washington Park High School 1948. Married Bucky Hanson July 22, 1950 at parents home in Racine (Elmwood Park). Member of Holy Communion Lutheran Church. Preceded in death by mother Emma, father Harry, and brother Dale Sorenson. Survived by husband Bucky Hanson and five sons: Dr. David, Steve, Rev. Dana, Jon, and Andrew Hanson. Eight grandchildren."
    },
    {
      "id": "person-bucky-hanson",
      "firstName": "Edward",
      "lastName": "Hanson",
      "nickname": "Bucky",
      "birthYear": "1930",
      "birthDate": "1930-07-21",
      "deathYear": "2019",
      "birthPlace": "Racine, Wisconsin",
      "notes": "CONFIRMED: obituary from Racine Journal Times (Feb 2022) and Legacy.com confirm Edward 'Bucky' Hanson was born July 21, 1930 in Racine, Wisconsin to Steven and Katherine (Jensen) Hanson. Married Nancy (Sorenson) Hanson at the home of her parents Harry and Emma Sorenson on July 22, 1950 in Racine, Wisconsin. Died in 2019. Five sons: Dr. David, Steve, Rev. Dana, Jon, and Andrew Hanson."
    },
