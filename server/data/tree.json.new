    {
      "id": "person-harry-sorenson",
      "firstName": "Harry Nels",
      "lastName": "Sorenson",
      "birthYear": "1898",
      "deathYear": "1979",
      "birthPlace": "Menominee, Menominee, Michigan, United States",
      "deathPlace": "Largo, Florida, United States",
      "notes": "Parent of Dale Harry Sorenson. Born 10 Dec 1898 in Menominee, Michigan; died 24 Mar 1979 in Largo, Florida; buried in Graceland Cemetery, Racine, Wisconsin. Married Emma Flora Timler on 15 Oct 1924 in Racine, Wisconsin. Lived in Kenosha, Wisconsin in 1940 and Mount Pleasant, Racine, Wisconsin in 1950. Parents: Julius Laurentius Sørensen and Anna Olsson."
    },
    {
      "id": "person-emma-timler",
      "firstName": "Emma Flora",
      "lastName": "Timler",
      "birthYear": "1904",
      "deathYear": "1990",
      "birthPlace": "Kovno, Kovno, Russian Empire",
      "birthDate": "1904-10-12",
      "deathDate": "1990-11-03",
      "deathPlace": "Seminole, Florida, United States",
      "notes": "Parent of Dale Harry Sorenson. Find a Grave memorial gives birth 12 Oct 1904 in Kovno, Russian Empire; death 3 Nov 1990 in Seminole, Florida; buried in Racine, Wisconsin. WikiTree gives birth place as Kovno, Kovno, Russian Empire. Harry and Emma married 15 Oct 1924 in Racine, Wisconsin (per WikiTree)."
    },
    {
      "id": "person-julius-sorenson",
      "firstName": "Julius Laurentius",
      "lastName": "Sørensen",
      "birthYear": "1865",
      "deathYear": "1932",
      "birthPlace": "Vesterborg, Halsted Klosters, Denmark",
      "birthDate": "1865-07-13",
      "deathDate": "1932-11-06",
      "notes": "Parent of Harry Nels Sorenson. Born 13 Jul 1865 in Vesterborg, Halsted Klosters, Denmark; died 6 Nov 1932 in Racine, Wisconsin; buried in Graceland Cemetery, Racine, Wisconsin. Married Anna Olsson on 9 Mar 1889 in Vesterborg, Halsted Klosters, Denmark. Immigrated to New York County, New York in 1891. Lived in Vesterborg, Denmark in 1890 and Racine, Wisconsin in 1920. Parents: Søren Nielsen and Johanne Lorentzen. They were the parents of at least 2 sons and 5 daughters."
    },
    {
      "id": "person-anna-olsson",
      "firstName": "Anna",
      "lastName": "Olsson",
      "birthYear": "1867",
      "deathYear": "1945",
      "birthPlace": "Sjörup, Malmöhus, Sweden",
      "notes": "CONFIRMED parent of Harry Nels Sorenson. Born 25 Jun 1867 in Sjörup, Malmöhus, Sweden; died 1 Nov 1945. WikiTree profile confirms Anna (Olsson) Sorenson as spouse of Julius Laurentius Sørensen."
    },
    {
      "id": "person-soren-nielsen",
      "firstName": "Søren",
      "lastName": "Nielsen",
      "notes": "Parent of Julius Laurentius Sørensen. Per Julius's own notes. Søren and Johanne had 7 children: Harry Nels Sorenson (1898–1979), Johanna (1889–1989), Selma Sissa (1890–1969), Ebba Bernadotte (1892–1967), Arthur Julius (1895–1988), Myrtle J (1897–1951), and Lily Ann (1900–1987). Specific birth/death dates and marriage record in Danish parish records (Vesterborg/Halsted) not yet located."
    },
    {
      "id": "person-johanne-lorentzen",
